# Backend - ejecución FUERA de Docker (la DB sí corre en Docker en localhost:5433)
# Copiar a .env y ajustar JWT_SECRET antes de levantar.
NODE_ENV=development
PORT=3000

# Base de datos: el contenedor 'db' de docker-compose expone 5433 en el host.
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_NAME=quiniela_mundial_2026
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_SSL=false

JWT_SECRET=local-dev-secret-change-me-please-123456
JWT_EXPIRES_IN=2h

# CORS: origen del frontend en dev (vite en 5173)
APP_CORS_ORIGIN=http://localhost:5173

# Admin inicial de ejemplo (opcional)
CREATE_INITIAL_ADMIN=true
ADMIN_EMAIL=admin@example.test
ADMIN_PASSWORD=ChangeMe123!

# TheSportsDB (plan gratuito, clave de prueba "3")
SPORTSDB_API_KEY=3
SPORTSDB_BASE_URL=https://www.thesportsdb.com/api/v1/json
SPORTSDB_LEAGUE_NAME=FIFA World Cup
SPORTSDB_WORLD_CUP_SEASON=2026
# SPORTSDB_WORLD_CUP_LEAGUE_ID=      # ID real del Mundial 2026 en TheSportsDB

# Sincronización incremental
# SYNC_ENABLED=true  -> ejecuta el cron cada 20 min (solo día actual).
# SYNC_ON_BOOT=true   -> al iniciar, sincroniza hoy + próximos (2 llamadas aprox).
SYNC_ENABLED=false
SYNC_ON_BOOT=false
