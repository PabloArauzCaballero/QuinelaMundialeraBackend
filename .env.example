NODE_ENV=development
PORT=3000
APP_NAME=Quiniela Mundial 2026 API
APP_CORS_ORIGIN=http://localhost:5173,http://localhost:3001

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=quiniela_mundial_2026
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_SSL=false
DATABASE_LOGGING=false

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=2h

# Seeds idempotentes. No se cargan partidos/equipos/estadios mock.
# En Render/demo, db:seed crea por defecto roles y credenciales demo controladas.
# Para apagar las credenciales demo en un entorno real: SEED_DEMO_USERS=false
SEED_DEMO_USERS=true
DEMO_ADMIN_NAME=Demo Admin
DEMO_ADMIN_EMAIL=demo.admin@quiniela.test
DEMO_ADMIN_PASSWORD=DemoAdmin123!
DEMO_USER_NAME=Demo User
DEMO_USER_EMAIL=demo.user@quiniela.test
DEMO_USER_PASSWORD=DemoUser123!

# Admin controlado adicional opcional. El seeder actualiza la contraseña si el usuario ya existe.
CREATE_INITIAL_ADMIN=false
ADMIN_NAME=Administrador
ADMIN_EMAIL=
ADMIN_PASSWORD=

RUN_DB_SEEDS=false

# TheSportsDB v1. La clave 123 es pública de documentación/free; reemplazar si tienes una propia.
SPORTSDB_API_KEY=123
SPORTSDB_BASE_URL=https://www.thesportsdb.com/api/v1/json
SPORTSDB_LEAGUE_NAME=FIFA World Cup
SPORTSDB_WORLD_CUP_LEAGUE_ID=
SPORTSDB_WORLD_CUP_SEASON=2026
SPORTSDB_TIMEOUT_MS=12000
SPORTSDB_CACHE_TTL_SECONDS=300
SYNC_ENABLED=false
